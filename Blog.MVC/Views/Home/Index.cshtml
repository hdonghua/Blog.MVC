@model HomeIndexViewModel
@{
    ViewData["Title"] = "首页";
}

<section class="hero-section">
    <div class="container site-container">
        <h1 class="hero-title">记录代码、生活与灵感</h1>
        <p class="hero-desc">技术实践、项目思考与生活片段。</p>
    </div>
</section>

<section class="section-block">
    <div class="container site-container">
        <div class="section-head">
            <h2>开源项目</h2>
        </div>

        @if (Model.OpenSourceProjects.Count == 0)
        {
            <div class="empty-state">
                <p>暂无开源项目展示。</p>
            </div>
        }
        else
        {
            <div class="project-grid">
                @foreach (var project in Model.OpenSourceProjects)
                {
                    <partial name="_OpenSourceProjectCard" model="project" />
                }
            </div>
        }
    </div>
</section>

<section class="section-block">
    <div class="container site-container">
        <div class="section-head">
            <h2>最新文章</h2>
            <a class="section-more" asp-controller="Blog" asp-action="Timeline">查看全部 →</a>
        </div>

        @if (Model.RecentArticles.Count == 0)
        {
            <div class="empty-state">
                <p>暂无已发布文章，请先在后台发布内容。</p>
            </div>
        }
        else
        {
            <div class="article-list">
                @foreach (var article in Model.RecentArticles)
                {
                    <partial name="_ArticleRow" model="article" />
                }
            </div>
        }
    </div>
</section>
