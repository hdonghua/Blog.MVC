@{
    ViewData["Title"] = "关于";
}

<section class="page-hero">
    <div class="container site-container">
        <h1>关于本站</h1>
        <p>一个温暖、简洁的个人博客空间。</p>
    </div>
</section>

<section class="section-block">
    <div class="container site-container site-container-narrow">
        <div class="about-card">
            <h2>你好，欢迎来访 👋</h2>
            <p>
                这里是 <strong>HBLOG</strong>，一个基于 ASP.NET Core MVC 构建的个人博客。
                我希望能在这里记录学习过程、技术实践，以及生活中值得留意的片段。
            </p>
            <p>
                本站采用简洁稳重的视觉风格，注重阅读体验与内容呈现。
                文章内容以 Markdown 撰写，支持分类与标签管理。
            </p>
            <div class="about-features">
                <div class="about-feature">
                    <span class="about-feature-icon">✦</span>
                    <div>
                        <strong>技术分享</strong>
                        <p>编程笔记、框架实践与项目总结</p>
                    </div>
                </div>
                <div class="about-feature">
                    <span class="about-feature-icon">✦</span>
                    <div>
                        <strong>生活随笔</strong>
                        <p>日常思考、阅读感悟与随想记录</p>
                    </div>
                </div>
                <div class="about-feature">
                    <span class="about-feature-icon">✦</span>
                    <div>
                        <strong>持续更新</strong>
                        <p>通过时间线纵览全部文章脉络</p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>
