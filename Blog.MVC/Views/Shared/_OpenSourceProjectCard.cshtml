@model OpenSourceProjectDto

<article class="project-card">
    <div class="project-card-icon" aria-hidden="true">&lt;/&gt;</div>
    <div class="project-card-body">
        <div class="project-card-head">
            <h3 class="project-card-title">
                <a href="@Model.RepositoryUrl" target="_blank" rel="noopener noreferrer">@Model.Name</a>
            </h3>
            @if (!string.IsNullOrWhiteSpace(Model.Language))
            {
                <span class="project-card-lang">@Model.Language</span>
            }
        </div>
        @if (!string.IsNullOrWhiteSpace(Model.Description))
        {
            <p class="project-card-desc">@Model.Description</p>
        }
        <div class="project-card-links">
            <a href="@Model.RepositoryUrl" target="_blank" rel="noopener noreferrer">仓库</a>
            @if (!string.IsNullOrWhiteSpace(Model.DemoUrl))
            {
                <a href="@Model.DemoUrl" target="_blank" rel="noopener noreferrer">演示</a>
            }
        </div>
    </div>
</article>
