<!DOCTYPE html>
<html lang="zh-CN">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - 个人博客</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
@{
    var controller = ViewContext.RouteData.Values["controller"]?.ToString();
    var action = ViewContext.RouteData.Values["action"]?.ToString();
    string NavClass(string c, string a = "Index") =>
        controller == c && action == a ? "nav-link active" : "nav-link";
}
<body class="site-body">
    <header class="site-header">
        <nav class="navbar navbar-expand-md site-navbar">
            <div class="container site-container">
                <div class="site-navbar-center">
                    <div class="site-navbar-group">
                        <a class="navbar-brand site-brand" asp-controller="Home" asp-action="Index">WarmLog</a>
                        <div class="collapse navbar-collapse site-nav-collapse" id="siteNav">
                            <ul class="navbar-nav site-nav">
                                <li class="nav-item">
                                    <a class="@NavClass("Home")" asp-controller="Home" asp-action="Index">首页</a>
                                </li>
                                <li class="nav-item">
                                    <a class="@NavClass("Blog", "Timeline")" asp-controller="Blog" asp-action="Timeline">时间线</a>
                                </li>
                                <li class="nav-item">
                                    <a class="@NavClass("Home", "About")" asp-controller="Home" asp-action="About">关于</a>
                                </li>
                            </ul>
                        </div>
                    </div>
                    <button class="navbar-toggler site-toggler ms-md-0" type="button" data-bs-toggle="collapse" data-bs-target="#siteNav"
                            aria-controls="siteNav" aria-expanded="false" aria-label="切换导航">
                        <span class="navbar-toggler-icon"></span>
                    </button>
                </div>
            </div>
        </nav>
    </header>

    <main class="site-main">
        @RenderBody()
    </main>

    <footer class="site-footer">
        <div class="container site-container">
            <div class="site-footer-inner">
                <nav class="site-footer-nav">
                    <a asp-controller="Home" asp-action="Index">首页</a>
                    <a asp-controller="Blog" asp-action="Timeline">时间线</a>
                    <a asp-controller="Home" asp-action="About">关于</a>
                    <a asp-area="Admin" asp-controller="Account" asp-action="Login">后台</a>
                </nav>
                <p class="site-footer-copy mb-0">&copy; @DateTime.Now.Year WarmLog · 记录思考与代码</p>
            </div>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
