@model Blog.MVC.IServices.Blog.Dtos.ArticleListDto
@{
    var hasCover = !string.IsNullOrWhiteSpace(Model.CoverImage);
}

<a class="article-row" asp-controller="Blog" asp-action="Detail" asp-route-slug="@Model.Slug">
    <div class="article-row-body">
        <h2 class="article-row-title">@Model.Title</h2>
        @if (!string.IsNullOrWhiteSpace(Model.Summary))
        {
            <p class="article-row-summary">@Model.Summary</p>
        }
        <div class="article-row-foot">
            <div class="article-row-stats">
                <span>@Model.ViewCount 阅读</span>
                <span class="article-row-stat-sep">·</span>
                <span>@Model.CommentCount 评论</span>
            </div>
            @if (Model.Tags.Count > 0)
            {
                <div class="article-row-tags">
                    @foreach (var tag in Model.Tags)
                    {
                        <span class="article-tag">@tag</span>
                    }
                </div>
            }
        </div>
    </div>
    @if (hasCover)
    {
        <div class="article-row-cover">
            <img src="@Model.CoverImage" alt="@Model.Title" loading="lazy" />
        </div>
    }
</a>
