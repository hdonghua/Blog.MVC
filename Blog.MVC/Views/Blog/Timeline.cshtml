@model TimelineViewModel
@inject Microsoft.Extensions.Configuration.IConfiguration Configuration
@{
    ViewData["Title"] = "时间线";
    ViewData["MetaDescription"] = string.IsNullOrWhiteSpace(Model.ActiveCategoryName) && string.IsNullOrWhiteSpace(Model.ActiveTagName)
        ? "按时间浏览全部博客文章"
        : $"浏览{(Model.ActiveCategoryName != null ? $"分类「{Model.ActiveCategoryName}」" : $"标签「{Model.ActiveTagName}」")}下的文章";
    ViewData["CanonicalUrl"] = Url.Action("Timeline", "Blog", new
    {
        category = Model.ActiveCategorySlug,
        tag = Model.ActiveTagSlug
    }, Context.Request.Scheme);
    var hasFilter = !string.IsNullOrWhiteSpace(Model.ActiveCategoryName)
        || !string.IsNullOrWhiteSpace(Model.ActiveTagName);
}

<section class="page-hero">
    <div class="container site-container">
        <h1>文章时间线</h1>
        @if (hasFilter)
        {
            <p class="timeline-hero-filter">
                @if (!string.IsNullOrWhiteSpace(Model.ActiveCategoryName))
                {
                    <span>分类：@Model.ActiveCategoryName</span>
                }
                @if (!string.IsNullOrWhiteSpace(Model.ActiveCategoryName) && !string.IsNullOrWhiteSpace(Model.ActiveTagName))
                {
                    <span class="timeline-hero-sep">·</span>
                }
                @if (!string.IsNullOrWhiteSpace(Model.ActiveTagName))
                {
                    <span>标签：#@Model.ActiveTagName</span>
                }
            </p>
        }
        else
        {
            <p>按发布时间纵览全部博客文章。</p>
        }
    </div>
</section>

<section class="section-block">
    <div class="container site-container site-container-narrow">
        <partial name="_TimelineFilters" model="Model" />

        @if (Model.Groups.Count == 0)
        {
            <div class="empty-state">
                <p>@(hasFilter ? "当前筛选条件下暂无文章。" : "暂无已发布文章。")</p>
                @if (hasFilter)
                {
                    <a class="btn btn-site-outline mt-3" asp-controller="Blog" asp-action="Timeline">查看全部</a>
                }
            </div>
        }
        else
        {
            <div class="timeline">
                @foreach (var group in Model.Groups)
                {
                    <div class="timeline-group">
                        <div class="timeline-label">@group.Label</div>
                        <div class="timeline-items">
                            @foreach (var article in group.Articles)
                            {
                                <article class="timeline-item">
                                    <div class="timeline-item-date">
                                        @((article.PublishedTime ?? article.CreationTime).ToLocalTime().ToString("MM-dd"))
                                    </div>
                                    <div class="timeline-item-body">
                                        <h3>
                                            <a class="timeline-item-title" asp-controller="Blog" asp-action="Detail" asp-route-slug="@article.Slug">@article.Title</a>
                                        </h3>
                                        <div class="timeline-item-meta">
                                            <a class="timeline-item-category"
                                               asp-controller="Blog" asp-action="Timeline"
                                               asp-route-category="@article.CategorySlug"
                                               asp-route-tag="@Model.ActiveTagSlug">@article.CategoryName</a>
                                        </div>
                                    </div>
                                    @if (!string.IsNullOrWhiteSpace(article.CoverImage))
                                    {
                                        <a class="timeline-item-cover" asp-controller="Blog" asp-action="Detail" asp-route-slug="@article.Slug">
                                            <img src="@article.CoverImage" alt="" loading="lazy" />
                                        </a>
                                    }
                                </article>
                            }
                        </div>
                    </div>
                }
            </div>
        }
    </div>
</section>
