@model CategoryFormViewModel

<div class="row g-3">
    <div class="col-md-6">
        <label asp-for="Name" class="form-label"></label>
        <input asp-for="Name" class="form-control" />
        <span asp-validation-for="Name" class="text-danger"></span>
    </div>
    <div class="col-md-6">
        <label asp-for="Slug" class="form-label"></label>
        <input asp-for="Slug" class="form-control" placeholder="留空则自动生成" />
    </div>
    <div class="col-12">
        <label asp-for="Description" class="form-label"></label>
        <textarea asp-for="Description" class="form-control" rows="3"></textarea>
    </div>
    <div class="col-md-4">
        <label asp-for="SortOrder" class="form-label"></label>
        <input asp-for="SortOrder" class="form-control" type="number" />
    </div>
</div>
