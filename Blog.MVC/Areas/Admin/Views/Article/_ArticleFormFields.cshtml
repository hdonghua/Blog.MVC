@model ArticleFormViewModel

<div class="row g-3">
    <div class="col-md-8">
        <div class="mb-3">
            <label asp-for="Title" class="form-label"></label>
            <input asp-for="Title" class="form-control" />
            <span asp-validation-for="Title" class="text-danger"></span>
        </div>
        <div class="mb-3">
            <label asp-for="Summary" class="form-label"></label>
            <textarea asp-for="Summary" class="form-control" rows="2"></textarea>
            <span asp-validation-for="Summary" class="text-danger"></span>
        </div>
        <div class="mb-3">
            <label asp-for="Content" class="form-label"></label>
            <div id="article-editor">
                <textarea asp-for="Content" style="display:none;"></textarea>
            </div>
            <span asp-validation-for="Content" class="text-danger"></span>
            <div class="form-text">支持 Markdown 语法，可直接插入图片（上传至 MinIO）。</div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="mb-3">
            <label asp-for="Status" class="form-label"></label>
            <select asp-for="Status" class="form-select" asp-items="Html.GetEnumSelectList<ArticleStatus>()"></select>
        </div>
        <div class="mb-3">
            <label asp-for="CategoryId" class="form-label"></label>
            <select asp-for="CategoryId" class="form-select" asp-items="Model.Categories"></select>
            <span asp-validation-for="CategoryId" class="text-danger"></span>
        </div>
        <div class="mb-3">
            <label class="form-label">标签</label>
            <div class="tag-picker" id="tagPicker">
                <input type="search" class="form-control form-control-sm tag-picker-search" placeholder="搜索标签…" autocomplete="off" />
                <div class="tag-picker-list">
                    @foreach (var tag in Model.Tags)
                    {
                        var selected = Model.SelectedTagIds.Contains(tag.Id);
                        <label class="tag-picker-item@(selected ? " is-selected" : "")" data-name="@tag.Name.ToLowerInvariant()">
                            <input class="tag-picker-input" type="checkbox" name="SelectedTagIds" value="@tag.Id"
                                   @(selected ? "checked" : "") />
                            <span class="tag-picker-chip">@tag.Name</span>
                        </label>
                    }
                </div>
                <div class="tag-picker-foot">
                    <span class="tag-picker-count">已选 <strong id="tagSelectedCount">@Model.SelectedTagIds.Count</strong> 个</span>
                </div>
            </div>
        </div>
        <div class="mb-3">
            <label asp-for="Slug" class="form-label"></label>
            <input asp-for="Slug" class="form-control" placeholder="留空则自动生成" />
        </div>
        <div class="mb-3">
            <label asp-for="CoverImage" class="form-label">封面图</label>
            <div class="cover-upload" id="coverUpload">
                <div class="cover-preview-wrap@(string.IsNullOrWhiteSpace(Model.CoverImage) ? " d-none" : "")" id="coverPreviewWrap">
                    <img id="coverPreview" src="@Model.CoverImage" alt="封面预览" />
                    <button type="button" class="btn btn-sm btn-outline-danger cover-remove-btn" id="coverRemoveBtn">移除</button>
                </div>
                <input asp-for="CoverImage" class="form-control cover-url-input" id="CoverImage" placeholder="图片 URL（可粘贴或上传）" />
                <div class="cover-upload-actions">
                    <label class="btn btn-outline-secondary btn-sm mb-0 cover-upload-btn">
                        上传封面
                        <input type="file" id="coverFileInput" accept="image/jpeg,image/png,image/gif,image/webp,image/bmp" hidden />
                    </label>
                    <span class="cover-upload-status" id="coverUploadStatus"></span>
                </div>
                <div class="form-text">支持 jpg / png / webp / gif，上传至 MinIO</div>
            </div>
        </div>
    </div>
</div>
