@using Microsoft.AspNetCore.Routing
@functions {
    RouteValueDictionary BuildPageRoutes(PaginationViewModel model, int page)
    {
        var routes = new RouteValueDictionary
        {
            ["page"] = page,
            ["pageSize"] = model.PageSize
        };

        foreach (var pair in model.RouteValues)
        {
            routes[pair.Key] = pair.Value;
        }

        return routes;
    }
}
@if (Model.TotalPages > 1)
{
    <nav class="admin-pagination d-flex justify-content-between align-items-center mt-3" aria-label="分页">
        <div class="text-muted small">
            共 @Model.TotalCount 条，第 @Model.Page / @Model.TotalPages 页
        </div>
        <ul class="pagination mb-0">
            <li class="page-item @(Model.HasPrevious ? "" : "disabled")">
                <a class="page-link"
                   asp-area="@Model.Area"
                   asp-controller="@Model.Controller"
                   asp-action="@Model.Action"
                   asp-all-route-data="BuildPageRoutes(Model, Model.Page - 1)">上一页</a>
            </li>
            @{
                var start = Math.Max(1, Model.Page - 2);
                var end = Math.Min(Model.TotalPages, Model.Page + 2);
            }
            @if (start > 1)
            {
                <li class="page-item">
                    <a class="page-link"
                       asp-area="@Model.Area"
                       asp-controller="@Model.Controller"
                       asp-action="@Model.Action"
                       asp-all-route-data="BuildPageRoutes(Model, 1)">1</a>
                </li>
                @if (start > 2)
                {
                    <li class="page-item disabled"><span class="page-link">…</span></li>
                }
            }
            @for (var i = start; i <= end; i++)
            {
                <li class="page-item @(i == Model.Page ? "active" : "")">
                    <a class="page-link"
                       asp-area="@Model.Area"
                       asp-controller="@Model.Controller"
                       asp-action="@Model.Action"
                       asp-all-route-data="BuildPageRoutes(Model, i)">@i</a>
                </li>
            }
            @if (end < Model.TotalPages)
            {
                @if (end < Model.TotalPages - 1)
                {
                    <li class="page-item disabled"><span class="page-link">…</span></li>
                }
                <li class="page-item">
                    <a class="page-link"
                       asp-area="@Model.Area"
                       asp-controller="@Model.Controller"
                       asp-action="@Model.Action"
                       asp-all-route-data="BuildPageRoutes(Model, Model.TotalPages)">@Model.TotalPages</a>
                </li>
            }
            <li class="page-item @(Model.HasNext ? "" : "disabled")">
                <a class="page-link"
                   asp-area="@Model.Area"
                   asp-controller="@Model.Controller"
                   asp-action="@Model.Action"
                   asp-all-route-data="BuildPageRoutes(Model, Model.Page + 1)">下一页</a>
            </li>
        </ul>
    </nav>
}
