@if (Model.TotalPages > 1)
{
    <nav class="admin-pagination d-flex justify-content-between align-items-center mt-3" aria-label="分页">
        <div class="text-muted small">
            共 @Model.TotalCount 条，第 @Model.Page / @Model.TotalPages 页
        </div>
        <ul class="pagination mb-0">
            <li class="page-item @(Model.HasPrevious ? "" : "disabled")">
                <a class="page-link"
                   asp-area="@Model.Area"
                   asp-controller="@Model.Controller"
                   asp-action="@Model.Action"
                   asp-route-page="@(Model.Page - 1)"
                   asp-route-pageSize="@Model.PageSize">上一页</a>
            </li>
            @{
                var start = Math.Max(1, Model.Page - 2);
                var end = Math.Min(Model.TotalPages, Model.Page + 2);
            }
            @if (start > 1)
            {
                <li class="page-item">
                    <a class="page-link" asp-area="@Model.Area" asp-controller="@Model.Controller" asp-action="@Model.Action" asp-route-page="1" asp-route-pageSize="@Model.PageSize">1</a>
                </li>
                @if (start > 2)
                {
                    <li class="page-item disabled"><span class="page-link">…</span></li>
                }
            }
            @for (var i = start; i <= end; i++)
            {
                <li class="page-item @(i == Model.Page ? "active" : "")">
                    <a class="page-link"
                       asp-area="@Model.Area"
                       asp-controller="@Model.Controller"
                       asp-action="@Model.Action"
                       asp-route-page="@i"
                       asp-route-pageSize="@Model.PageSize">@i</a>
                </li>
            }
            @if (end < Model.TotalPages)
            {
                @if (end < Model.TotalPages - 1)
                {
                    <li class="page-item disabled"><span class="page-link">…</span></li>
                }
                <li class="page-item">
                    <a class="page-link"
                       asp-area="@Model.Area"
                       asp-controller="@Model.Controller"
                       asp-action="@Model.Action"
                       asp-route-page="@Model.TotalPages"
                       asp-route-pageSize="@Model.PageSize">@Model.TotalPages</a>
                </li>
            }
            <li class="page-item @(Model.HasNext ? "" : "disabled")">
                <a class="page-link"
                   asp-area="@Model.Area"
                   asp-controller="@Model.Controller"
                   asp-action="@Model.Action"
                   asp-route-page="@(Model.Page + 1)"
                   asp-route-pageSize="@Model.PageSize">下一页</a>
            </li>
        </ul>
    </nav>
}
