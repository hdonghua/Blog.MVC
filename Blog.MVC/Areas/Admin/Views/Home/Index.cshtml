@model DashboardViewModel
@{
    ViewData["Title"] = "仪表盘";
}

<div class="row g-4">
    <div class="col-md-3">
        <div class="card border-0 shadow-sm">
            <div class="card-body">
                <div class="text-muted small">文章</div>
                <div class="display-6 fw-bold">@Model.ArticleCount</div>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card border-0 shadow-sm">
            <div class="card-body">
                <div class="text-muted small">分类</div>
                <div class="display-6 fw-bold">@Model.CategoryCount</div>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card border-0 shadow-sm">
            <div class="card-body">
                <div class="text-muted small">标签</div>
                <div class="display-6 fw-bold">@Model.TagCount</div>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card border-0 shadow-sm">
            <div class="card-body">
                <div class="text-muted small">用户</div>
                <div class="display-6 fw-bold">@Model.UserCount</div>
            </div>
        </div>
    </div>
    <div class="col-12">
        <div class="card border-0 shadow-sm">
            <div class="card-body d-flex justify-content-between align-items-center">
                <div>
                    <h5 class="card-title mb-1">欢迎回来，@Model.CurrentUserName</h5>
                    <p class="text-muted mb-0">在后台发布富文本文章，并管理分类与标签。</p>
                </div>
                <a class="btn btn-primary" asp-area="Admin" asp-controller="Article" asp-action="Create">发布文章</a>
            </div>
        </div>
    </div>
</div>
