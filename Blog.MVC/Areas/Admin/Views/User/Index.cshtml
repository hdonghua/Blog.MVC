@model PagedResult<UserDto>
@{
    ViewData["Title"] = "用户管理";
}

<div class="page-toolbar d-flex justify-content-end">
    <a class="btn btn-primary" asp-action="Create">新建用户</a>
</div>

<div class="card">
    <div class="table-responsive">
        <table class="table table-hover mb-0 align-middle">
            <thead class="table-light">
                <tr>
                    <th>ID</th>
                    <th>用户名</th>
                    <th>显示名称</th>
                    <th>邮箱</th>
                    <th>角色</th>
                    <th>状态</th>
                    <th>创建时间</th>
                    <th class="text-end">操作</th>
                </tr>
            </thead>
            <tbody>
            @foreach (var user in Model.Items)
            {
                <tr>
                    <td>@user.Id</td>
                    <td>@user.UserName</td>
                    <td>@(user.DisplayName ?? "-")</td>
                    <td>@user.Email</td>
                    <td><span class="badge text-bg-secondary">@user.Role</span></td>
                    <td>
                        @if (user.IsActive)
                        {
                            <span class="badge text-bg-success">启用</span>
                        }
                        else
                        {
                            <span class="badge text-bg-danger">禁用</span>
                        }
                    </td>
                    <td>@user.CreationTime.ToString("yyyy-MM-dd HH:mm")</td>
                    <td class="text-end">
                        <a class="btn btn-sm btn-outline-primary" asp-action="Edit" asp-route-id="@user.Id">编辑</a>
                        <a class="btn btn-sm btn-outline-danger" asp-action="Delete" asp-route-id="@user.Id">删除</a>
                    </td>
                </tr>
            }
            </tbody>
        </table>
    </div>
</div>

<partial name="_Pagination" model="ViewBag.Pagination" />
